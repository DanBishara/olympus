{
    "version": 2,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20
    },
    "configurePresets": [
        {
            "name": "build_53KIT_TES",
            "displayName": "Build for nRF5340 DK nRF5340 application MCU Non Secure",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build_53KIT_TES",
            "cacheVariables": {
                "BOARD": "nrf5340dk/nrf5340/cpuapp/ns",
                "EXTRA_CONF_FILE": "boards/Devkits/53Devkit/sensor.conf",
                "CONF_FILE": "prj.conf",
                "EXTRA_DTC_OVERLAY_FILE": "boards/Devkits/53Devkit/sensor.dts;boards/Devkits/53Devkit/nrf5340dk.dts"
            }
        },
        {
            "name": "build_54KIT",
            "displayName": "Build for nRF54l15 DK nRF54l15 Application",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build_54KIT",
            "cacheVariables": {
                "BOARD": "nrf54l15dk/nrf54l15/cpuapp",
                "DEBUG_THREAD_INFO": false,
                "olympus_DEBUG_THREAD_INFO": false
            }
        }
    ]
}