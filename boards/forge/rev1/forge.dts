#include <zephyr/dt-bindings/sensor/lsm6dso.h>

/ {
    aliases {
        led0 = &mcu_debug;
        my-int = &max30101_int;
        boost-en = &boost_en;
        boost-sel = &boost_sel;
        user-memory = &storage_partition;
    };
    leds {
		compatible = "gpio-leds";

        status = "okay";

		mcu_debug: led_0 {
			gpios = <&gpio1 10 GPIO_ACTIVE_HIGH>;
			label = "MCU debug LED";
		};

        boost_en: boost_en {
            gpios = <&gpio1 3 GPIO_ACTIVE_HIGH>;
            label = "Boost enable";
        };

        boost_sel: boost_sel {
            gpios = <&gpio1 2 GPIO_ACTIVE_HIGH>;
            label = "Boost select";
        };
	};
    ppg_int {
        compatible = "gpio-keys";
        max30101_int: gang {
            gpios = <&gpio0 4 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
        };
    };

    
};
&gpiote30 {
    status = "okay";
};

&gpiote20 {
    status = "okay";
};

&i2c30 {
	status = "okay";

    pinctrl-0 = <&i2c1_default>;
    pinctrl-1 = <&i2c1_sleep>;
    pinctrl-names = "default", "sleep";

	accelerometer: lsm6dso@6a {
        status = "okay";
		compatible = "st,lsm6dso";
		reg = <0x6a>;                   // 0x6a if SDO=0, use 0x6b if SDO=1
		label = "LSM6DSOX";
		irq-gpios = <&gpio1 7 GPIO_ACTIVE_HIGH>;
		int-pin = <1>;          // 1 = INT1, 2 = INT2
        accel-pm = <LSM6DSO_DT_XL_ULP_MODE>;
        accel-range = <LSM6DSO_DT_FS_2G>;
        accel-odr = <LSM6DSO_DT_ODR_12Hz5>;
        gyro-pm = <LSM6DSO_DT_GY_NORMAL_MODE>;
	};

    ppg: max30101@57 {
        status = "okay";
        compatible = "maxim,max30101";
        reg = <0x57>; // the datasheet says 0xae, but devboard said 0x57, may run into issues laters
    };
};

&clock {
    status = "okay";
};

&radio {
    status = "okay";
};

